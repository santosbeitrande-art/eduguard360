# Environment: development | production
NODE_ENV=development

# Server
PORT=3000
HOST=localhost

# Database PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=ecotrade_app
DATABASE_PASSWORD=secure_password
DATABASE_NAME=ecotrade360
DATABASE_URL=postgresql://ecotrade_app:secure_password@localhost:5432/ecotrade360

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_1234567890
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_super_secret_refresh_key_1234567890
JWT_REFRESH_EXPIRES_IN=30d

# OTP Service (Twilio para SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE=+351XXXXXXXXX

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# AWS S3 (para imagens)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=eu-west-1
AWS_S3_BUCKET=ecotrade360

# Firebase (para notificações)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
FIREBASE_DATABASE_URL=your_firebase_database_url
FIREBASE_PROJECT_ID=your_firebase_project_id

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@ecotrade360.pt

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
