{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/public",
      "destination": "/public/index.html"
    },
    {
      "source": "/public/",
      "destination": "/public/index.html"
    },
    {
      "source": "/public/login",
      "destination": "/public/login.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}