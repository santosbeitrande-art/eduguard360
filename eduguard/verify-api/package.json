{
  "name": "eduguard-verify-api",
  "version": "0.1.0",
  "main": "src/index.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "worker": "ts-node-dev --respawn --transpile-only src/worker.ts",
    "dev:online": "node scripts/dev-online.mjs",
    "db:migrate": "node scripts/migrate-sqlserver.mjs",
    "db:migrate:pg": "node scripts/migrate-postgres.mjs",
    "bootstrap:online": "node scripts/bootstrap-online.mjs",
    "security:housekeeping": "node scripts/security-housekeeping.mjs",
    "build": "tsc",
    "benchmark:fraud": "npm run build && node -e \"const { runInternalBenchmark } = require('./dist/internal_benchmark.js'); console.log(JSON.stringify(runInternalBenchmark(), null, 2));\"",
    "test": "npm run test:fraud",
    "test:fraud": "npm run build && node --test dist/__tests__/fraud-calibration.test.js"
  },
  "dependencies": {
    "adm-zip": "^0.6.0",
    "cors": "^2.8.5",
    "exif-parser": "^0.1.12",
    "express": "^4.18.2",
    "image-size": "^1.0.1",
    "localtunnel": "^2.0.2",
    "mammoth": "^1.12.0",
    "mime-types": "^2.1.35",
    "multer": "^1.4.4",
    "node-fetch": "^3.3.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.22.0",
    "redis": "^6.1.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.5",
    "@types/express": "^4.17.17",
    "@types/mime-types": "^2.0.0",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
